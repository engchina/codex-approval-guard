{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Approval Guard",
  "version": "0.1.2",
  "identifier": "com.engchina.codex-approval-guard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Approval Guard",
        "width": 440,
        "height": 600,
        "minWidth": 400,
        "minHeight": 520,
        "maxWidth": 550,
        "maxHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
